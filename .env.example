# ===========================================
# ClearFall Protocol - Environment Variables
# ===========================================

# -------------------------------------------
# Deployment (Hardhat)
# -------------------------------------------

# Your deployer wallet private key (WITHOUT 0x prefix)
PRIVATE_KEY=your_private_key_here

# RPC URLs
AMOY_RPC_URL=https://rpc-amoy.polygon.technology
POLYGON_RPC_URL=https://polygon-rpc.com

# Polygonscan API Key (for contract verification)
# Get from: https://polygonscan.com/apis
POLYGONSCAN_API_KEY=your_polygonscan_api_key

# -------------------------------------------
# Indexer (Optional - MongoDB)
# -------------------------------------------

# MongoDB connection string
# Get from: https://cloud.mongodb.com/
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/clearfall

# Factory address (set after deployment)
FACTORY_ADDRESS=0x3f10025Ad4abddFa48eC05B63FFa84f71DA2d814

# Polygon RPC for indexer
POLYGON_RPC_URL=https://rpc-amoy.polygon.technology
