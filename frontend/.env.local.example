# ===========================================
# ClearFall Frontend - Environment Variables
# ===========================================
# Copy this file to .env.local and fill in the values
# For Vercel: Add these in Project Settings > Environment Variables

# -------------------------------------------
# REQUIRED: WalletConnect
# -------------------------------------------
# Get your project ID from: https://cloud.walletconnect.com/
# 1. Sign up / Sign in
# 2. Create a new project (select "App" type)
# 3. Copy the Project ID
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id

# -------------------------------------------
# REQUIRED: Contract Address
# -------------------------------------------
# Factory contract address on Polygon Amoy
# Get this after running: npx hardhat run scripts/deploy.ts --network amoy
NEXT_PUBLIC_FACTORY_ADDRESS=0xYourFactoryAddressHere

# -------------------------------------------
# Network Configuration (defaults work for Amoy)
# -------------------------------------------
# Chain ID: 80002 = Polygon Amoy, 137 = Polygon Mainnet
NEXT_PUBLIC_CHAIN_ID=80002

# RPC URL (Polygon Amoy public RPC)
NEXT_PUBLIC_RPC_URL=https://rpc-amoy.polygon.technology

# -------------------------------------------
# IPFS/Pinata Configuration (for metadata storage)
# -------------------------------------------
# Get your JWT from: https://app.pinata.cloud/
# 1. Sign up / Sign in to Pinata
# 2. Go to API Keys section
# 3. Create a new API key with pinning permissions
# 4. Copy the JWT token
NEXT_PUBLIC_PINATA_JWT=your_pinata_jwt_token

# Optional: Custom Pinata gateway (uses public gateway by default)
NEXT_PUBLIC_PINATA_GATEWAY=https://gateway.pinata.cloud/ipfs

# -------------------------------------------
# VERCEL DEPLOYMENT NOTES:
# -------------------------------------------
# 1. Go to your Vercel project dashboard
# 2. Settings > Environment Variables
# 3. Add each variable above
# 4. Make sure to add for all environments (Production, Preview, Development)
#
# Required variables for Vercel:
# - NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID
# - NEXT_PUBLIC_FACTORY_ADDRESS
# - NEXT_PUBLIC_CHAIN_ID
# - NEXT_PUBLIC_RPC_URL
# - NEXT_PUBLIC_PINATA_JWT (for IPFS uploads)
